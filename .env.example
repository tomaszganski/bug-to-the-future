# Google Sheets Integration
# Get this URL by deploying the Google Apps Script as a Web App
# See the Apps Script code in the project documentation
VITE_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Google Analytics 4 — Measurement ID from Admin → Data streams (format G-XXXXXXXXXX)
# Leave unset to disable analytics in dev or builds without tracking
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
